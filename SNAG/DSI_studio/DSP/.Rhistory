all_SI_df %>% ggplot(aes(
x = factor(age_group, levels = c("Young", "Midlife")),
y = dsp_success_pct,
fill = age_group
)) + geom_boxplot(width = 1,
fatten = 1,
outliers = FALSE) +
geom_jitter(width = 0.3, size = 8) +
#geom_point(size=2) +
scale_fill_manual(values = c("#7d4c5a", "#6c6c6e")) +
scale_y_continuous(breaks = seq(0, 1, by = 0.2)) +
xlab("Age Group") +
ylab("Wayfinding Success (%)") +
theme(
axis.title.x = element_text(vjust = -3, size = 40, face = "bold"),
axis.title.y = element_text(vjust = 4, size = 40,face = "bold"),
axis.text.x = element_text(
size = 30,
color = "black",
vjust = -2,
face = "bold"
),
axis.text.y = element_text(
size = 30,
color = "black",
hjust = 2,
face = "bold"
),
axis.ticks.y = element_line(color = "black",
linewidth =2 ),
axis.ticks.x = element_blank(),
axis.ticks.length = unit(0.75, "cm"),
panel.background = element_blank(),
axis.line = element_line(colour = "black", linewidth = 3),
legend.position = "none",
plot.margin = margin(2,2, 2, 2, "cm"),
)
dev.off()
