hormone_comparison <-  data.frame(matrix(ncol = 5, nrow = 0)) %>% `colnames<-`(c("hormone","statistic","p.value","method","alternative"))
#Estradiol
est_wilx_test <- wilcox.test(Mid_dsp_pre_df$estradiol_spatial_pg_ml, Mid_dsp_peripost_df$estradiol_spatial_pg_ml) %>% broom::tidy() %>%  mutate(hormone = "Estradiol") %>% dplyr::select("hormone",everything())
hormone_comparison <- rbind(hormone_comparison, est_wilx_test)
# FSH
FSH_wilx_test <- wilcox.test(Mid_dsp_pre_df$fsh_spatial_miu_ml, Mid_dsp_peripost_df$fsh_spatial_miu_ml) %>% broom::tidy() %>%  mutate(hormone = "FSH") %>% dplyr::select("hormone",everything())
hormone_comparison <- rbind(hormone_comparison, FSH_wilx_test)
# Progesterone
prog_wilx_test <- wilcox.test(Mid_dsp_pre_df$progesterone_spatial_ng_ml, Mid_dsp_peripost_df$progesterone_spatial_ng_ml) %>% broom::tidy() %>%  mutate(hormone = "Progesterone") %>% dplyr::select("hormone",everything())
options(scipen=999)
p_corrected <- p.adjust(hormone_comparison$p.value, "BY")
hormone_comparison <- hormone_comparison %>% mutate(p.value.BYCorrected = p_corrected)
hormone_comparison%>% kableExtra::kable() %>% kable_styling(bootstrap_options =  c("striped", "hover", "condensed"))
