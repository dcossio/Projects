y = dsp_success_pct,
fill = age_group
)) + geom_boxplot(width = 0.5,
fatten = 1,
outliers = FALSE,
linewidth = 2,
color="black") +
#geom_jitter(width = 0.3, size = 8) +
geom_point(position=position_jitterdodge(0.2, dodge.width = .2),size=2) +
#geom_point(size=2) +
scale_fill_manual(values = c("#7d4c5a", "#997C5C")) +
scale_y_continuous(breaks = seq(0, 1, by = 0.2)) +
xlab("Age Group") +
ylab("Wayfinding Success (%)") +
