panel.background = element_blank(),
axis.line = element_line(colour = "black", linewidth = 1),
legend.position = "none",
plot.margin = margin(1,1 , 1, 1, "cm"),
)
midlife_HP_df_adj %>% ggplot(aes(x = avg_t1_hipp,y = loop_pe_avg_m)) +
geom_point(aes(size=3)) +
#scale_color_manual(values = c("#4e363e", "#CCBDCA")) +
stat_smooth(method = "lm",
formula = y ~ x,
geom = "smooth",
color="Black",
se=TRUE)+
scale_y_continuous(breaks = seq(0, 150, by = 25)) +
xlab("Averaged GMV Volume")+
ylab("Position Error at average (m)") +
theme(
axis.title.x = element_text(vjust = -4, size = 24, face = "bold"),
axis.title.y = element_text(vjust = 4, size = 24,face = "bold"),
axis.text.x = element_text(
size = 18,
color = "black",
vjust = -2,
face = "bold"
),
axis.text.y = element_text(
size = 18,
color = "black",
hjust = 1,
face = "bold"
),
axis.ticks.y = element_line(color = "black",
linewidth =1 ),
#axis.ticks.x = element_blank(),
axis.ticks.length = unit(0.25, "cm"),
panel.background = element_blank(),
axis.line = element_line(colour = "black", linewidth = 1),
legend.position = "none",
plot.margin = margin(1,1, 1, 1, "cm"),
)
# Use hp data frame adjusted
ggscatter(midlife_HP_df_adj, x = "avg_t1_hipp", y = "loop_pe_rad3_m",
add = "reg.line",
add.params = list(color = "black", fill = "lightgray"), # Customize reg. line
cor.coef = TRUE, # Add correlation coefficient. see ?stat_cor
conf.int = TRUE,
cor.method = "pearson",
cor.coeff.args = list(label.sep = "\n"),
xlab = "Averaged GMV Volume", ylab = "Position Error at aver3.0  (m)", ) +
theme(legend.position = "top", legend.title=element_blank())
