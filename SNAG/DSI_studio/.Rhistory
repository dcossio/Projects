#geom_point(size=2) +
scale_fill_manual(values = c("#7d4c5a", "#997C5C")) +
scale_y_continuous(breaks = seq(0, 1, by = 0.2)) +
xlab("Age Group") +
ylab("loop_de_avg_degree") +
theme(
