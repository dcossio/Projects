sub_info$REPO[sub_info$REPO==2]<-c("Peri_Post")
sub_info$REPO[sub_info$REPO==3]<-c("Peri_Post")
#Creating group DF
df_maze_fem <- sub_info %>% filter(SEX == "Female")
