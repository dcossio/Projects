sub_info <- read.csv(paste0(working_dir,"MazeDSI.csv")) # this is a csv that contains all of the important subject information.
sub_info$SEX[sub_info$SEX==1]<-c("Male")
sub_info$SEX[sub_info$SEX==0]<-c("Female")
